    for (int i = 0; i < kullanici_sayisi; i++) {
        if (kullanicilar[i].aktif &&
            strcmp(kullanicilar[i].kullanici_adi, kadi) == 0 &&
            strcmp(kullanicilar[i].sifre_hash,    hash) == 0) {
