                case PERSONEL: printf("[PERSONEL]\n");   break;
                case OGRENCI:  printf("[OGRENCI]\n");    break;
                default: break;
            }
            return 1;
        }
    }
    printf("\n[HATA] Kullanici adi veya şifre yanlis!\n");
    return 0;
}

