/*
   ÖDÜNÇ ALMA & İADE  (İş Paketi 4)
*/

void kitap_odunc_al(void) {
    int kitap_id;
    printf("Odunc alinacak kitap ID: "); scanf("%d", &kitap_id);

    /* Kitap var mı? */
    Kitap *k = NULL;
    for (int i = 0; i < kitap_sayisi; i++)
        if (kitaplar[i].id == kitap_id && kitaplar[i].aktif) { k = &kitaplar[i]; break; }
    if (!k) { printf("[HATA] Kitap bulunamadi.\n"); return; }
    if (k->mevcut <= 0) { printf("[HATA] Stokta kitap yok.\n"); return; }

    /* Aynı kullanıcı zaten almış mı? */
    for (int i = 0; i < odunc_sayisi; i++) {
        if (oduncler[i].kullanici_id == aktif_kullanici->id &&
            oduncler[i].kitap_id    == kitap_id &&
            oduncler[i].durum       == ODUNC_AKTIF) {
            printf("[HATA] Bu kitabi zaten odunc almissiniz.\n"); return;
        }
    }
    if (odunc_sayisi >= MAX_ODUNC) { printf("[HATA] Kayit kapasitesi dolu.\n"); return; }

    OduncKayit o = {0};
    o.id             = yeni_odunc_id();
    o.kullanici_id   = aktif_kullanici->id;
    o.kitap_id       = kitap_id;
    bugun_tarih(o.odunc_tarih);
    iade_tarihi_hesapla(o.odunc_tarih, ODUNC_SURE_GUN, o.iade_tarih);
    o.durum          = ODUNC_AKTIF;

    k->mevcut--;
    oduncler[odunc_sayisi++] = o;
    tum_verileri_kaydet();

    printf("[OK] Kitap odunc alindi.\n");
    printf("     Odunc tarihi : %s\n", o.odunc_tarih);
    printf("     Iade tarihi  : %s\n", o.iade_tarih);
}

void kitap_iade_et(void) {
    int odunc_id;
    printf("İade edilecek odunc ID: "); scanf("%d", &odunc_id);

    for (int i = 0; i < odunc_sayisi; i++) {
        OduncKayit *o = &oduncler[i];
        if (o->id == odunc_id && o->durum == ODUNC_AKTIF) {
            /* Yetki: kendi kaydı mı veya personel/yönetici mi? */
            if (aktif_kullanici->rol == OGRENCI &&
                o->kullanici_id != aktif_kullanici->id) {
                printf("[YETKI HATASI] Baskasinin kaydini iade edemezsiniz.\n"); return;
            }
            bugun_tarih(o->gercek_iade);
            o->durum = ODUNC_IADE;

            /* Gecikme kontrolü */
            int fark = gun_farki(o->iade_tarih, o->gercek_iade);
            if (fark > 0)
                printf("[UYARI] %d gün gecikmeli iade! Ceza uygulanabilir.\n", fark);
            else
                printf("[OK] Zamaninda iade. Tesekkürler.\n");

            /* Stok geri ver */
            for (int j = 0; j < kitap_sayisi; j++)
                if (kitaplar[j].id == o->kitap_id) { kitaplar[j].mevcut++; break; }

            tum_verileri_kaydet();
            return;
        }
    }
    printf("[HATA] Aktif odunc kaydi bulunamadi.\n");
}

/*
   KİTAP ARAMA & LİSTELEME  (İş Paketi 5)
*/

/* Küçük harf dönüşüm */
static void kucult(char *dst, const char *src) {
    while (*src) {
        char c = *src++;
        if (c >= 'A' && c <= 'Z') c += 32;
        *dst++ = c;
    }
    *dst = '\0';
}

void kitap_ara(void) {
    char arama[100], a_kucuk[100], b_kucuk[200];
    int  kriter;
    printf("Arama kriteri (1=Ad, 2=Yazar, 3=ISBN, 4=Yayinevi): ");
    scanf("%d", &kriter);
    printf("Arama terimi: "); scanf(" %99[^\n]", arama);
    kucult(a_kucuk, arama);

    int bulunan = 0;
    printf("\n%-5s %-30s %-25s %-8s %-6s\n",
           "ID", "Ad", "Yazar", "Yil", "Mevcut");
    printf("%-5s %-30s %-25s %-8s %-6s\n",
           "---","---","---","---","---");

    for (int i = 0; i < kitap_sayisi; i++) {
        if (!kitaplar[i].aktif) continue;
        const char *alan = "";
        switch (kriter) {
            case 1: alan = kitaplar[i].ad;       break;
            case 2: alan = kitaplar[i].yazar;    break;
            case 3: alan = kitaplar[i].isbn;     break;
            case 4: alan = kitaplar[i].yayinevi; break;
            default: alan = kitaplar[i].ad;
        }
        kucult(b_kucuk, alan);
        if (strstr(b_kucuk, a_kucuk)) {
            printf("%-5d %-30.30s %-25.25s %-8d %-6d\n",
                   kitaplar[i].id,
                   kitaplar[i].ad,
                   kitaplar[i].yazar,
                   kitaplar[i].yayin_yili,
                   kitaplar[i].mevcut);
            bulunan++;
        }
    }
    printf("\nToplam %d sonuç bulundu.\n", bulunan);
}

/* Bubble Sort – ada göre */
void kitaplari_sirala_ad(void) {
    for (int i = 0; i < kitap_sayisi - 1; i++)
        for (int j = 0; j < kitap_sayisi - i - 1; j++)
            if (strcmp(kitaplar[j].ad, kitaplar[j+1].ad) > 0) {
                Kitap tmp = kitaplar[j];
                kitaplar[j]   = kitaplar[j+1];
                kitaplar[j+1] = tmp;
            }
}

void tum_kitaplari_listele(void) {
    kitaplari_sirala_ad();
    printf("\n%-5s %-20s %-30s %-20s %-8s %-5s %-5s %-10s\n",
           "ID","ISBN","Ad","Yazar","Yayinevi","Yil","Mevcut","Konum");
    printf("%-5s %-20s %-30s %-20s %-8s %-5s %-5s %-10s\n",
           "---","---","---","---","---","---","---","---");
    int sayac = 0;
    for (int i = 0; i < kitap_sayisi; i++) {
        if (!kitaplar[i].aktif) continue;
        printf("%-5d %-20.20s %-30.30s %-20.20s %-8.8s %-5d %-5d %-10.10s\n",
               kitaplar[i].id,
               kitaplar[i].isbn,
               kitaplar[i].ad,
               kitaplar[i].yazar,
               kitaplar[i].yayinevi,
               kitaplar[i].yayin_yili,
               kitaplar[i].mevcut,
               kitaplar[i].konum);
        sayac++;
    }
    printf("\nToplam %d kitap.\n", sayac);
}

/*
   RAPORLAMA & İSTATİSTİKLER  (İş Paketi 6)
*/

void envanter_ozeti(void) {
    baslik_yazdir("ENVANTER OZETI");
    int toplam = 0, mevcut = 0, oduncte = 0;
    for (int i = 0; i < kitap_sayisi; i++) {
        if (!kitaplar[i].aktif) continue;
        toplam  += kitaplar[i].stok;
        mevcut  += kitaplar[i].mevcut;
        oduncte += kitaplar[i].stok - kitaplar[i].mevcut;
    }
    printf("Toplam kitap cesidi : %d\n", kitap_sayisi);
    printf("Toplam stok         : %d\n", toplam);
    printf("Mevcut (rafta)      : %d\n", mevcut);
    printf("Oduncte             : %d\n", oduncte);
    printf("Aktif kullanici     : ");
    int ak = 0;
    for (int i = 0; i < kullanici_sayisi; i++) if (kullanicilar[i].aktif) ak++;
    printf("%d\n", ak);
}

void geckmis_iadeler(void) {
    baslik_yazdir("GECIKMIS IADELER");
    char bugun[12];
    bugun_tarih(bugun);
    int bulunan = 0;

    printf("%-6s %-20s %-30s %-12s %-12s %-6s\n",
           "ÖdID","Kullanici","Kitap","Iade Tarihi","Bugun","Gecikme");
    printf("%-6s %-20s %-30s %-12s %-12s %-6s\n",
           "---","---","---","---","---","---");

    for (int i = 0; i < odunc_sayisi; i++) {
        OduncKayit *o = &oduncler[i];
        if (o->durum != ODUNC_AKTIF) continue;
        int fark = gun_farki(o->iade_tarih, bugun);
        if (fark <= 0) continue;

        /* Kullanıcı adı */
        char kad[40] = "?";
        for (int j = 0; j < kullanici_sayisi; j++)
            if (kullanicilar[j].id == o->kullanici_id)
                { strncpy(kad, kullanicilar[j].ad_soyad, 39); break; }

        /* Kitap adı */
        char kad2[30] = "?";
        for (int j = 0; j < kitap_sayisi; j++)
            if (kitaplar[j].id == o->kitap_id)
                { strncpy(kad2, kitaplar[j].ad, 29); break; }

        printf("%-6d %-20.20s %-30.30s %-12s %-12s %-6d\n",
               o->id, kad, kad2, o->iade_tarih, bugun, fark);
        bulunan++;
    }
    if (!bulunan) printf("Gecikmis iade yok.\n");
}

void populer_kitaplar(void) {
    baslik_yazdir("EN COK ODUNC ALINAN KITAPLAR (Top 5)");

    int sayac[MAX_KITAP] = {0};
    for (int i = 0; i < odunc_sayisi; i++)
        for (int j = 0; j < kitap_sayisi; j++)
            if (kitaplar[j].id == oduncler[i].kitap_id) { sayac[j]++; break; }

    /* Basit seçim sıralaması (azalan) */
    int siralama[MAX_KITAP];
    for (int i = 0; i < kitap_sayisi; i++) siralama[i] = i;
    for (int i = 0; i < kitap_sayisi - 1; i++)
        for (int j = i + 1; j < kitap_sayisi; j++)
            if (sayac[siralama[j]] > sayac[siralama[i]]) {
                int t = siralama[i]; siralama[i] = siralama[j]; siralama[j] = t;
            }

    int limit = kitap_sayisi < 5 ? kitap_sayisi : 5;
    printf("%-5s %-35s %-25s %-8s\n", "Sira","Kitap Adi","Yazar","Odunc");
    printf("%-5s %-35s %-25s %-8s\n","---","---","---","---");
    for (int i = 0; i < limit; i++) {
        int idx = siralama[i];
        if (!kitaplar[idx].aktif) continue;
        printf("%-5d %-35.35s %-25.25s %-8d\n",
               i+1,
               kitaplar[idx].ad,
               kitaplar[idx].yazar,
               sayac[idx]);
    }
}

