/* Kitap ekle */
void kitap_ekle(void) {
    if (aktif_kullanici->rol == OGRENCI) {
        printf("[YETKI HATASI] Bu islemi yapamazsiniz.\n"); return;
    }
    if (kitap_sayisi >= MAX_KITAP) {
        printf("[HATA] Maksimum kitap sayisina ulaşildi.\n"); return;
    }
    Kitap k = {0};
    k.id     = yeni_kitap_id();
    k.aktif  = 1;

    printf("ISBN        : "); scanf("%19s", k.isbn);
    printf("Kitap adi   : "); scanf(" %99[^\n]", k.ad);
    printf("Yazar       : "); scanf(" %79[^\n]", k.yazar);
    printf("Yayinevi    : "); scanf(" %79[^\n]", k.yayinevi);
    printf("Yayin yili  : "); scanf("%d", &k.yayin_yili);
    printf("Stok adedi  : "); scanf("%d", &k.stok);
    k.mevcut = k.stok;
    printf("Konum (raf) : "); scanf("%29s", k.konum);

    kitaplar[kitap_sayisi++] = k;
    kitaplari_kaydet();
    printf("[OK] Kitap eklendi. (ID: %d)\n", k.id);
}

/* Kitap güncelle */
void kitap_guncelle(void) {
    if (aktif_kullanici->rol == OGRENCI) {
        printf("[YETKI HATASI] Bu islemi yapamazsiniz.\n"); return;
    }
    int id;
    printf("Guncellenecek kitap ID: "); scanf("%d", &id);
    for (int i = 0; i < kitap_sayisi; i++) {
        if (kitaplar[i].id == id && kitaplar[i].aktif) {
            Kitap *k = &kitaplar[i];
            printf("Yeni ad   (mevcut: %s): ", k->ad);     scanf(" %99[^\n]", k->ad);
            printf("Yeni yazar(mevcut: %s): ", k->yazar);  scanf(" %79[^\n]", k->yazar);
            printf("Yeni stok (mevcut: %d): ", k->stok);
            int yeni_stok; scanf("%d", &yeni_stok);
            k->mevcut += (yeni_stok - k->stok);
            k->stok    = yeni_stok;
            printf("Yeni konum(mevcut: %s): ", k->konum);  scanf("%29s", k->konum);
            kitaplari_kaydet();
            printf("[OK] Kitap guncellendi.\n");
            return;
        }
    }
    printf("[HATA] Kitap bulunamadi.\n");
}

/* Kitap sil */
void kitap_sil(void) {
    if (aktif_kullanici->rol != YONETICI) {
        printf("[YETKI HATASI] Sadece yoneticiler silebilir.\n"); return;
    }
    int id;
    printf("Silinecek kitap ID: "); scanf("%d", &id);
    for (int i = 0; i < kitap_sayisi; i++) {
        if (kitaplar[i].id == id && kitaplar[i].aktif) {
            /* Aktif ödünç var mı? */
            for (int j = 0; j < odunc_sayisi; j++) {
                if (oduncler[j].kitap_id == id && oduncler[j].durum == ODUNC_AKTIF) {
                    printf("[HATA] Kitabin aktif odunc kaydi var, silinemez.\n");
                    return;
                }
            }
            kitaplar[i].aktif = 0;
            kitaplari_kaydet();
            printf("[OK] Kitap silindi.\n");
            return;
        }
    }
    printf("[HATA] Kitap bulunamadi.\n");
}

