void ana_menu(void) {
    int sec;
    do {
        baslik_yazdir("ANA MENU");
        printf("Giris: %s  [%s]\n\n",
               aktif_kullanici->ad_soyad,
               aktif_kullanici->rol == YONETICI ? "YONETICI" :
               aktif_kullanici->rol == PERSONEL ? "PERSONEL" : "OGRENCİ");

        printf("1. Kitap Islemleri\n");
        printf("2. Odunc / Iade Islemleri\n");
        if (aktif_kullanici->rol == YONETICI)
            printf("3. Kullanici Yonetimi\n");
        if (aktif_kullanici->rol != OGRENCI)
            printf("4. Raporlar & Istatistikler\n");
        printf("0. Cikis / Oturumu Kapat\n");
        printf("Seçim: "); scanf("%d", &sec);

        switch (sec) {
            case 1: kitap_menusu();    break;
            case 2: odunc_menusu();    break;
            case 3:
                if (aktif_kullanici->rol == YONETICI) kullanici_menusu();
                break;
            case 4:
                if (aktif_kullanici->rol != OGRENCI) rapor_menusu();
                break;
        }
    } while (sec != 0);
    aktif_kullanici = NULL;
}

