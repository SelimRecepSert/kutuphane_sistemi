/* Basit XOR hash */
void sifre_hashle(const char *sifre, char *cikti) {
    unsigned int h = 5381;
    const char *p = sifre;
    while (*p) { h = ((h << 5) + h) ^ (unsigned char)*p++; }
    sprintf(cikti, "%u", h);
}

/* Bugünün tarihini YYYY-MM-DD formatında döndürür */
void bugun_tarih(char *tampon) {
    time_t now = time(NULL);
    struct tm *t = localtime(&now);
    strftime(tampon, 12, "%Y-%m-%d", t);
}

/* İade tarihini hesapla */
void iade_tarihi_hesapla(const char *baslangic, int gun, char *sonuc) {
    struct tm t = {0};
    sscanf(baslangic, "%d-%d-%d", &t.tm_year, &t.tm_mon, &t.tm_mday);
    t.tm_year -= 1900;
    t.tm_mon  -= 1;
    time_t ts = mktime(&t);
    ts += (time_t)gun * 86400;
    struct tm *r = localtime(&ts);
    strftime(sonuc, 12, "%Y-%m-%d", r);
}

/* İki tarih arasındaki gün farkı */
int gun_farki(const char *t1, const char *t2) {
    struct tm a = {0}, b = {0};
    sscanf(t1, "%d-%d-%d", &a.tm_year, &a.tm_mon, &a.tm_mday);
    sscanf(t2, "%d-%d-%d", &b.tm_year, &b.tm_mon, &b.tm_mday);
    a.tm_year -= 1900; a.tm_mon -= 1;
    b.tm_year -= 1900; b.tm_mon -= 1;
    double sn = difftime(mktime(&b), mktime(&a));
    return (int)(sn / 86400);
}

